{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sqlite": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "--experimental-strip-types",
        "packages/opencode-adapter/src/sqlite-mcp.ts",
        "data/local.db"
      ],
      "timeout": 30000
    },
    "brave-search": {
      "enabled": false
    },
    "gptr-mcp": {
      "enabled": false
    }
  }
}
