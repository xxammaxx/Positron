# Positron — Environment Configuration
# Kopiere diese Datei nach .env und passe sie an.

# === Pflicht (muss gesetzt werden) ===
GITHUB_TOKEN=                                # GitHub Personal Access Token (repo scope)
POSITRON_REPO_OWNER=                         # GitHub Owner (User oder Organisation)
POSITRON_REPO_NAME=                          # GitHub Repository Name

# === GitHub Modus ===
# "real" = gegen echtes GitHub, "fake" = simulierte API (für Tests)
GITHUB_MODE=fake

# === Safety Gates (Schutz vor Fehlbedienung) ===
# Standardmäßig sind alle mutierenden Aktionen AUS.
POSITRON_ENABLE_PUSH=false                   # true = Git Push erlauben
POSITRON_ENABLE_MERGE=false                  # true = Auto-Merge erlauben
POSITRON_MERGE_DRY_RUN=true                  # true = Merge simulieren (kein echter API-Call)
# POSITRON_MERGE_KILL_SWITCH=false           # Default: true (Merges blockiert). Explizit auf 'false' setzen um Merges zu erlauben.
                                             # MUSS zusammen mit POSITRON_ENABLE_MERGE=true gesetzt werden.

# === Fix-Loop ===
POSITRON_ENABLE_FIX_LOOP=false               # true = Automatischer Retry bei transienten Fehlern
POSITRON_MAX_FIX_LOOPS=3                     # Maximale Retry-Versuche (1-10)

# === CLI-Adapter ===
# "real" = echte CLI-Ausführung, "fake" = simulierte Ausgabe
POSITRON_SPECKIT_MODE=fake                   # real | fake
POSITRON_OPENCODE_MODE=fake                  # real | fake

# === Reviewer-Automation ===
# Komma-separierte Liste von GitHub Usernames oder Team-Slugs
# Nur wirksam wenn PR erstellt wird und GITHUB_MODE=real
POSITRON_PR_REVIEWERS=                       # z.B. "user1,user2"
POSITRON_PR_TEAM_REVIEWERS=                  # z.B. "my-team"

# === Repository-Konfiguration ===
# Optional: Überschreibt automatisch ermittelte Werte
POSITRON_REPO_DEFAULT_BRANCH=main
# POSITRON_REPO_REMOTE_URL=                  # Nur setzen bei abweichender Remote-URL
# POSITRON_WORKSPACE_ROOT=/tmp/positron-workspaces

# === Live-E2E-Tests ===
# Nur für Entwickler/CI — im Normalbetrieb nicht setzen
# POSITRON_ENABLE_LIVE_GITHUB_TESTS=false
# POSITRON_LIVE_TEST_ALLOW_WRITE=false
