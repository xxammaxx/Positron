# Positron v0.2.0 — Environment Configuration
# Containerized Deployment MVP — Safe Demo Defaults
#
# Copy this file to .env for local development:
#   cp .env.example apps/server/.env
#
# For containerized deployment, env vars are set in docker-compose.yml.
# This file documents all available settings.
#
# ⚠️  SAFETY: Positron starts in SAFE DEMO MODE by default.
#    - No real GitHub API calls (fake adapter)
#    - No real OpenCode/SpecKit execution
#    - Tool Gateway sealed/disabled
#    - Merge kill switch active
#    - Real runs disabled
#    To enable real operations, you must explicitly set each mode to 'real'.

# ── Positron Server ────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Core Mode ──────────────────────────────────────────
# Safe demo mode out-of-the-box: no secrets required
POSITRON_MODE=fake

# ── Adapter Modes (fake | real) ────────────────────────
# Real modes require external tools (OpenCode CLI, SpecKit CLI, GitHub token)
POSITRON_GITHUB_MODE=fake
POSITRON_SPECKIT_MODE=fake
POSITRON_OPENCODE_MODE=fake

# ── Data & Storage ─────────────────────────────────────
# SQLite database path (container: /app/data/)
POSITRON_DB_PATH=.positron/runs/positron.db
# Infrastructure state store: sqlite | memory
POSITRON_INFRASTRUCTURE_STORE=sqlite
# Data directory for container volumes
POSITRON_DATA_DIR=/app/data

# ── Safety Gates (ALL disabled by default) ─────────────
# Real run execution — DISABLED by default
POSITRON_ENABLE_REAL_RUN=false

# Tool Gateway — SEALED/DISABLED by default
POSITRON_ENABLE_TOOL_GATEWAY=false
# MCP server exposure — DISABLED by default
POSITRON_MCP_EXPOSE_ENABLED=false

# Merge safety
POSITRON_ENABLE_MERGE=false
POSITRON_MERGE_DRY_RUN=true
POSITRON_MERGE_KILL_SWITCH=true
POSITRON_ENABLE_AUTO_MERGE=false

# Push safety
POSITRON_ENABLE_PUSH=false

# Fix loop safety
POSITRON_ENABLE_FIX_LOOP=false
# POSITRON_MAX_FIX_LOOPS=3

# ── Infrastructure State Upserts — DISABLED by default ──
POSITRON_ENABLE_INFRASTRUCTURE_STATE_UPSERT=false

# ── GitHub Configuration (only needed for real mode) ───
# For demo/container mode, these defaults use fake adapters only:
POSITRON_REPO_OWNER=positron-demo
POSITRON_REPO_NAME=positron-demo
POSITRON_REPO_DEFAULT_BRANCH=main

# For real mode (NOT needed for demo):
# GITHUB_TOKEN=ghp_your_token_here
# POSITRON_PR_REVIEWERS=
# POSITRON_PR_TEAM_REVIEWERS=

# ── Workspace ──────────────────────────────────────────
# Container default: /app/workspace
# Only needed for real workspace operations
# POSITRON_WORKSPACE_ROOT=/tmp/positron-workspaces

# ── Web UI ─────────────────────────────────────────────
# Path to built web dist (auto-detected in most cases)
# POSITRON_WEB_DIST_PATH=apps/web/dist

# ── Admin API ──────────────────────────────────────────
# Token required for /api/admin/* endpoints
# POSITRON_ADMIN_TOKEN=your-secure-token-here

# ── Redis (optional — not needed for demo mode) ────────
# POSITRON_REDIS_URL=redis://localhost:6379

# ── Logging ────────────────────────────────────────────
# debug | info | warn | error (default: info)
# POSITRON_LOG_LEVEL=info

# ── CORS ───────────────────────────────────────────────
# Container default: allow same origin
# POSITRON_CORS_ORIGIN=http://localhost:5173

# ── Demo ───────────────────────────────────────────────
# POSITRON_DEFAULT_ISSUE_NUMBER=56
# POSITRON_ENABLE_DEMO_LIVE=false
# POSITRON_STRICT_TEST_MODE=false
