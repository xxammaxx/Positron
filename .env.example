# Positron v3.0 — Environment Configuration
# Kopiere diese Datei nach apps/server/.env und passe sie an.
#
# ⚠️  PRODUCTION: Setze ALLE Mode-Vars auf 'real' UND konfiguriere
#    GITHUB_TOKEN, POSITRON_REPO_OWNER, POSITRON_REPO_NAME

# ── Positron Server ────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Adapter-Modi (fake | real) ─────────────────────────
# PRODUCTION: Alle 3 auf 'real' setzen!
POSITRON_GITHUB_MODE=fake   # 'real' für echte GitHub-API (GITHUB_TOKEN erforderlich)
POSITRON_SPECKIT_MODE=fake  # 'real' für echtes SpecKit-CLI
POSITRON_OPENCODE_MODE=fake # 'real' für echtes OpenCode-CLI

# ── Feature Flags ──────────────────────────────────────
POSITRON_ENABLE_REAL_SPECKIT=false
POSITRON_ENABLE_DOGFOOD_FIXTURE_CHANGE=false
POSITRON_ENABLE_PUSH=false
POSITRON_ENABLE_MERGE=false
POSITRON_MERGE_DRY_RUN=true
POSITRON_MERGE_KILL_SWITCH=false
POSITRON_ENABLE_FIX_LOOP=false

# Max Fix-Loop-Wiederholungen (default: 3)
# POSITRON_MAX_FIX_LOOPS=3

# ── GitHub Adapter (nur wenn POSITRON_GITHUB_MODE=real) ─
# Erstelle unter: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
POSITRON_REPO_OWNER=your_github_username
POSITRON_REPO_NAME=your_repo_name
POSITRON_REPO_DEFAULT_BRANCH=main

# ── Datenbank ─────────────────────────────────────────
# Standard: ~/.positron/positron.db
# Für Tests: :memory:
POSITRON_DB_PATH=.positron/runs/positron.db

# ── Logging ────────────────────────────────────────────
# debug | info | warn | error (default: info)
# POSITRON_LOG_LEVEL=info

# ── Demo-Modus ─────────────────────────────────────────
POSITRON_DEFAULT_ISSUE_NUMBER=56

# ── Demo-Live-Endpunkt in Production aktivieren ──────────
# Nur für Entwickler-Demos — NIEMALS in Production setzen
# POSITRON_ENABLE_DEMO_LIVE=false

# ── Pull Request ─────────────────────────────────────────────
# Kommagetrennte GitHub-Usernames
POSITRON_PR_REVIEWERS=
POSITRON_PR_TEAM_REVIEWERS=

# ── Repository-Konfiguration ─────────────────────────────────
# Optional: Überschreibt automatisch ermittelte Werte
# POSITRON_REPO_REMOTE_URL=
# POSITRON_WORKSPACE_ROOT=/tmp/positron-workspaces

# ── Live-E2E-Tests ───────────────────────────────────────────
# Nur für Entwickler/CI — im Normalbetrieb nicht setzen
# POSITRON_ENABLE_LIVE_GITHUB_TESTS=false
# POSITRON_LIVE_TEST_ALLOW_WRITE=false
