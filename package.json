{
	"name": "positron",
	"version": "0.1.0",
	"private": true,
	"description": "Evidence-Gated GitHub Issue Execution System",
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"build": "tsc -b packages/shared packages/sandbox packages/github-adapter packages/run-state packages/speckit-adapter packages/opencode-adapter apps/server apps/worker",
		"build:watch": "tsc --build --watch",
		"dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
		"dev:server": "npm run build && node apps/server/dist/index.js",
		"dev:web": "vite apps/web",
		"coverage": "vitest run --coverage",
		"coverage:safety": "vitest run --config vitest.safety.config.ts --coverage",
		"test": "vitest run && cd apps/web && npx vitest run",
		"test:watch": "vitest",
		"test:contracts": "vitest run --config vitest.contracts.config.ts",
		"test:integration": "vitest run apps/server/src/__tests__/integration.test.ts",
		"test:mutation:fast": "stryker run stryker.fast.config.json",
		"test:mutation:safety": "stryker run stryker.safety.config.json",
		"test:e2e": "playwright test",
		"test:e2e:headed": "cross-env PW_HEADED=1 playwright test --headed --workers=1",
		"test:e2e:slow": "cross-env PW_HEADED=1 PW_SLOWMO=1000 playwright test --headed --workers=1",
		"test:e2e:observe": "cross-env PW_HEADED=1 PW_SLOWMO=1000 PW_OBSERVE=1 playwright test --headed --workers=1",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "cross-env PWDEBUG=1 PW_HEADED=1 playwright test --debug --workers=1",
		"e2e:ui-workflow": "playwright test e2e/ui-workflow-trace.spec.ts --workers=1",
		"test:e2e:watch": "cross-env PWTEST_WATCH=1 playwright test --ui",
		"test:e2e:diag": "cross-env PW_HEADED=1 PW_OBSERVE=1 PW_OBSERVE_TIMEOUT=30000 playwright test e2e/diagnostic-visible.spec.ts --headed --workers=1",
		"test:e2e:live-observe": "cross-env PW_HEADED=1 PW_SLOWMO=1000 PW_OBSERVE=1 PW_OBSERVE_TIMEOUT=120000 playwright test e2e/live-operations-visible.spec.ts --headed --workers=1",
		"demo:live": "cross-env PW_HEADED=1 PW_SLOWMO=800 PW_OBSERVE=1 PW_OBSERVE_TIMEOUT=120000 playwright test e2e/live-operations-visible.spec.ts --headed --workers=1",
		"demo:open": "node scripts/demo-live.mjs",
		"demo:open:no-browser": "node scripts/demo-live.mjs --no-browser",
		"demo:url": "node scripts/demo-live.mjs --no-browser",
		"demo:firefox": "cross-env BROWSER=firefox node scripts/demo-live.mjs",
		"demo:chrome": "cross-env BROWSER=google-chrome node scripts/demo-live.mjs",
		"demo:chrome-stable": "cross-env BROWSER=google-chrome-stable node scripts/demo-live.mjs",
		"demo:chromium": "cross-env BROWSER=chromium node scripts/demo-live.mjs",
		"demo:stop": "node scripts/demo-stop.mjs",
		"verify:issues": "node scripts/verify-issues.mjs all",
		"verify:issue": "node scripts/verify-issues.mjs",
		"observability:drill": "node scripts/observability-drill.mjs",
		"observability:validate": "node scripts/observability-validate.mjs",
		"observability:chaos-drill": "node scripts/chaos-drill.mjs",
		"observability:webhook-mock": "node scripts/alert-webhook-mock.mjs",
		"observability:queue-backlog": "node scripts/queue-backlog-drill.mjs",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"clean": "find . -name dist -not -path '*/node_modules/*' -exec rm -rf {} +",
		"typecheck": "tsc -b --dry",
		"dev:demo": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
		"doctor": "node scripts/doctor.mjs",
		"verify": "npm test && npm run test:contracts && npm run typecheck && npm run build && npm run coverage:safety"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/typescript-checker": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@types/node": "^22.0.0",
		"@biomejs/biome": "^1.9.4",
		"@vitest/coverage-v8": "^4.1.7",
		"concurrently": "^8.2.0",
		"cross-env": "^10.1.0",
		"fast-check": "^4.8.0",
		"prom-client": "^15.1.3",
		"typescript": "^5.4.0",
		"vitest": "^4.0.0"
	}
}
